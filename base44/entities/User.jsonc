{
  "name": "User",
  "type": "object",
  "properties": {
    "role": {
      "type": "string",
      "description": "The role of the user in the app",
      "enum": [
        "admin",
        "user"
      ]
    },
    "client_type": {
      "type": "string",
      "description": "Type of client account",
      "enum": [
        "enterprise",
        "teacher"
      ],
      "default": "enterprise"
    }
  },
  "required": [
    "role"
  ]
}